# ─── Supabase (shared VPS with nexus-crm) ──────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── n8n (shared VPS) ──────────────────────────────────────────────────
N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=

# Workflow-specific webhook URLs (NEWS - * prefix)
NEWS_INGEST_WEBHOOK_URL=
NEWS_CURATE_WEBHOOK_URL=
NEWS_SCRIPT_WEBHOOK_URL=
NEWS_RENDER_WEBHOOK_URL=
NEWS_EDIT_WEBHOOK_URL=
NEWS_PUBLISH_WEBHOOK_URL=
NEWS_TELEGRAM_WEBHOOK_URL=

# ─── Telegram (control surface) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                # Your personal chat ID (whitelist)
TELEGRAM_WEBHOOK_SECRET=         # Random string for validating Telegram callbacks
TELEGRAM_ALLOWED_USER_IDS=       # Comma-separated user IDs allowed to approve

# ─── LLM (script generation + curation) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai              # openai | anthropic
LLM_MODEL=gpt-4o                 # or claude-sonnet-4-6, etc.

# ─── ElevenLabs (voice) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Hedra (avatar/video) ──────────────────────────────────────────────
HEDRA_API_KEY=
HEDRA_CHARACTER_ID=
HEDRA_VOICE_ID=

# ─── News sources ──────────────────────────────────────────────────────
NEWSAPI_KEY=

# ─── YouTube ───────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_DEFAULT_CATEGORY=25      # News & Politics

# ─── Branding / editorial config ───────────────────────────────────────
CHANNEL_NAME=
CHANNEL_TONE=neutral             # neutral | analytical | conversational
VIDEO_TARGET_SECONDS=120
INTRO_VIDEO_PATH=
OUTRO_VIDEO_PATH=
