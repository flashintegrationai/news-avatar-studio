{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "News Avatar Studio — mixed Claude+Codex agent configuration. Permissions declared explicitly per tool category. Production-mutating actions require user confirmation.",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(supabase migration:*)",
      "Bash(supabase db push)",
      "Bash(ffmpeg:*)",
      "mcp__supabase__list_tables",
      "mcp__supabase__list_migrations",
      "mcp__supabase__execute_sql",
      "mcp__supabase__generate_typescript_types",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__list_pull_requests",
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__claude_ai_n8n__search_workflows",
      "mcp__claude_ai_n8n__search_nodes",
      "mcp__claude_ai_n8n__search_folders",
      "mcp__claude_ai_n8n__get_node_types",
      "mcp__claude_ai_n8n__get_sdk_reference",
      "mcp__claude_ai_n8n__get_workflow_details",
      "mcp__claude_ai_n8n__validate_workflow",
      "mcp__claude_ai_n8n__test_workflow",
      "mcp__claude_ai_n8n__prepare_test_pin_data"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm:*)",
      "mcp__supabase__apply_migration",
      "mcp__supabase__delete_branch",
      "mcp__supabase__deploy_edge_function",
      "mcp__claude_ai_n8n__create_workflow_from_code",
      "mcp__claude_ai_n8n__update_workflow",
      "mcp__claude_ai_n8n__publish_workflow",
      "mcp__claude_ai_n8n__unpublish_workflow",
      "mcp__claude_ai_n8n__execute_workflow",
      "mcp__claude_ai_n8n__archive_workflow",
      "mcp__github__create_repository",
      "mcp__github__merge_pull_request",
      "mcp__github__push_files"
    ],
    "deny": [
      "Bash(supabase db reset:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)"
    ]
  },
  "agent_permissions": {
    "youtube-publisher": {
      "note": "Publishing to YouTube is irreversible. Always require explicit user approval before calling YouTube upload."
    },
    "n8n-automation-engineer": {
      "note": "May create/update workflows in MCP-staged state but MUST NOT publish without approval."
    },
    "supabase-engineer": {
      "note": "May write migrations to disk. Applying migrations to remote requires user confirmation."
    }
  }
}
